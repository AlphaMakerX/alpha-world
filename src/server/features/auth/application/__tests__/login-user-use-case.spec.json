[
  {
    "name": "用户名密码正确时返回登录成功",
    "input": {
      "username": "testuser",
      "password": "password123"
    },
    "expected": {
      "ok": true,
      "user": {
        "id": "user-1",
        "username": "testuser"
      }
    }
  },
  {
    "name": "用户不存在时返回失败",
    "input": {
      "username": "testuser",
      "password": "password123"
    },
    "expected": {
      "ok": false,
      "error": "用户名或密码错误"
    }
  },
  {
    "name": "密码错误时返回失败",
    "input": {
      "username": "testuser",
      "password": "password123"
    },
    "expected": {
      "ok": false,
      "error": "用户名或密码错误"
    }
  },
  {
    "name": "用户不存在和密码错误返回同一错误信息",
    "input": {
      "场景A": "用户不存在",
      "场景B": "密码错误"
    },
    "expected": {
      "场景A与场景B返回结果相同": true
    }
  },
  {
    "name": "用户名格式非法时抛出 DomainError",
    "input": {
      "username": "ab",
      "password": "password123"
    },
    "expected": {
      "throws": "用户名长度必须在 3 到 32 之间"
    }
  },
  {
    "name": "验证密码时传入正确参数",
    "input": {
      "username": "testuser",
      "password": "password123"
    },
    "expected": {
      "passwordHasher.verify 参数": [
        "password123",
        "hashed-password"
      ]
    }
  }
]
