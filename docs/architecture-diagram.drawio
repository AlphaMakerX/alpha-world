  </diagram>

  <diagram id="data-flow" name="数据流与经济系统">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="flow-title" value="Alpha World — 数据流与经济系统" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="700" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 请求链路 ===== -->
        <mxCell id="chain-title" value="请求链路" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="30" as="geometry" />
        </mxCell>

        <mxCell id="browser" value="浏览器" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="react-comp" value="React&#xa;组件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="130" width="80" height="60" as="geometry" />
        </mxCell>

        <mxCell id="trpc-c" value="tRPC&#xa;Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="130" width="80" height="60" as="geometry" />
        </mxCell>

        <mxCell id="http-layer" value="HTTP&#xa;/api/trpc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="130" width="90" height="60" as="geometry" />
        </mxCell>

        <mxCell id="trpc-s" value="tRPC&#xa;Router" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="590" y="130" width="80" height="60" as="geometry" />
        </mxCell>

        <mxCell id="usecase" value="Use Case&#xa;(应用层)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="730" y="130" width="90" height="60" as="geometry" />
        </mxCell>

        <mxCell id="domain" value="Domain&#xa;(领域层)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="880" y="130" width="90" height="60" as="geometry" />
        </mxCell>

        <mxCell id="repo" value="Repository&#xa;(Drizzle)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1030" y="130" width="90" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pg" value="PostgreSQL" style="shape=cylinder3;whiteSpace=wrap;html=1;size=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="120" width="80" height="80" as="geometry" />
        </mxCell>

        <!-- Arrows for chain -->
        <mxCell id="a1" style="strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="browser" target="react-comp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a2" style="strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="react-comp" target="trpc-c"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a3" style="strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="trpc-c" target="http-layer"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a4" style="strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="http-layer" target="trpc-s"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a5" style="strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="trpc-s" target="usecase"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a6" style="strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="usecase" target="domain"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a7" style="strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="domain" target="repo"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a8" style="strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="repo" target="pg"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ===== 经济流转 ===== -->
        <mxCell id="econ-title" value="经济系统流转" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#333;" vertex="1" parent="1">
