        <mxCell id="raw" value="原材料采购&#xa;(消耗资金)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="700" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="produce" value="生产加工&#xa;(消耗时间)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
