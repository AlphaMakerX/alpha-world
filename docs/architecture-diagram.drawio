        <mxCell id="bc-plot-uc" value="Use Cases:&#xa;· PurchasePlotUseCase&#xa;  (资金校验 → 锁定 → 转账 → 变更所有权)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="bc-plot">
          <mxGeometry x="15" y="260" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="bc-plot-infra" value="Infrastructure:&#xa;· plots schema · DrizzlePlotRepository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=11;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="bc-plot">
          <mxGeometry x="15" y="335" width="230" height="30" as="geometry" />
        </mxCell>

        <!-- Building Context -->
        <mxCell id="bc-building" value="建筑上下文&#xa;Building Context" style="swimlane;startSize=40;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;rounded=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="890" y="100" width="280" height="550" as="geometry" />
        </mxCell>
        <mxCell id="bc-bld-agg" value="Aggregate Root: Building&#xa;· id, plotId, type, level, position&#xa;· type: residential | factory&#xa;         | shop | purchasing_station&#xa;&#xa;Behaviors:&#xa;· upgrade() · transferOwner()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="bc-building">
          <mxGeometry x="15" y="55" width="250" height="120" as="geometry" />
        </mxCell>
        <mxCell id="bc-bld-concepts" value="Domain Concepts:&#xa;· FactoryRecipeCatalog (配方目录)&#xa;· ProductionJob (生产任务)&#xa;· Inventory (背包/库存)&#xa;· ShopListing (商店挂单)&#xa;· BuyOrder (收购订单)&#xa;· ItemStack { itemKey, quantity }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="bc-building">
          <mxGeometry x="15" y="190" width="250" height="120" as="geometry" />
        </mxCell>
        <mxCell id="bc-bld-uc" value="Use Cases:&#xa;· BuildBuildingUseCase&#xa;· StartProductionUseCase&#xa;· CollectProductionUseCase&#xa;· CreateShopListingUseCase&#xa;· PurchaseShopListingUseCase&#xa;· CreateBuyOrderUseCase&#xa;· FulfillBuyOrderUseCase" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="bc-building">
          <mxGeometry x="15" y="325" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="bc-bld-infra" value="Infrastructure:&#xa;· plot_buildings, inventories, factory_production_jobs,&#xa;  shop_listings, buy_orders schema&#xa;· DrizzleBuildingRepository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=11;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="bc-building">
          <mxGeometry x="15" y="470" width="250" height="65" as="geometry" />
        </mxCell>

        <!-- Shared Kernel -->
        <mxCell id="bc-shared" value="共享内核 Shared Kernel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="540" width="420" height="60" as="geometry" />
        </mxCell>
        <mxCell id="bc-shared-content" value="DomainError · Adam 常量 (ID: 00000000-...-000000000001, 初始资金) · Result 类型" style="text;html=1;fontSize=11;align=center;verticalAlign=middle;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="400" y="600" width="420" height="30" as="geometry" />
