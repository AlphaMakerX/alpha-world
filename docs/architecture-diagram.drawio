        <!-- Arrows between contexts -->
        <mxCell id="auth-to-person" value="创建用户" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999;strokeWidth=1;dashed=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;fontSize=10;" edge="1" parent="1" source="bc-auth" target="bc-person">
