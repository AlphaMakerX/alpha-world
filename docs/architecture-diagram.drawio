        <mxCell id="plot-to-person" value="资金转账" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999;strokeWidth=1;dashed=1;exitX=0;exitY=0.7;entryX=1;entryY=0.7;fontSize=10;" edge="1" parent="1" source="bc-plot" target="bc-person">
