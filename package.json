{
  "name": "alpha-world",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8080",
    "dev:local": "dotenv -e .env.local -- next dev -p 8080",
    "dev:dev": "dotenv -e .env.development -- next dev -p 8080",
    "dev:prod": "dotenv -e .env.production -- next dev -p 8080",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "drizzle:push": "dotenv -e .env.local drizzle-kit push",
    "init:system": "dotenv -e .env.local -- tsx scripts/initialize-system.ts",
    "seed:plots:p1": "dotenv -e .env.local -- node --import tsx scripts/seed-plots-p1.ts"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.12.0",
    "@trpc/react-query": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "antd": "^6.3.2",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "phaser": "^3.90.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.4.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
